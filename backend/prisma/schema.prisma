generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String @unique
  users User[]
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  phone          String?
  avatarUrl      String?
  title          String?
  country        String?
  timezone       String   @default("Asia/Kolkata")
  language       String   @default("English")
  currency       String   @default("INR")
  emailNotifications     Boolean @default(true)
  orderNotifications     Boolean @default(true)
  messageNotifications   Boolean @default(true)
  marketingNotifications Boolean @default(false)
  profileVisibility      String  @default("PUBLIC")
  showOnlineStatus       Boolean @default(true)
  passwordHash   String
  roleId         Int
  role           Role     @relation(fields: [roleId], references: [id])
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Seller profile
  providerProfile ProviderProfile?

  // Marketplace services created by this user
  services        Service[]
  buyerOrders     Order[]   @relation("BuyerOrders")
  sellerOrders    Order[]   @relation("SellerOrders")
  orderMessages   OrderMessage[]
  disputesRaised  Dispute[] @relation("RaisedDisputes")
  disputesBuyer   Dispute[] @relation("BuyerDisputes")
  disputesSeller  Dispute[] @relation("SellerDisputes")
  disputeMessages DisputeMessage[]
  reviewsGiven    Review[]  @relation("ReviewerReviews")
  reviewsReceived Review[]  @relation("RevieweeReviews")
}

model ProviderProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  bio             String?
  experienceYears Int?
  baseHourlyRate  Float?
  serviceRadiusKm Float?
  averageRating   Float    @default(0)
  totalReviews    Int      @default(0)
  verified        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String
  price       Float
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Seller relationship
  sellerId Int
  seller   User @relation(fields: [sellerId], references: [id])
  orders   Order[]
  images   ServiceImage[]
}

model ServiceImage {
  id        Int      @id @default(autoincrement())
  serviceId Int
  fileUrl   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

model Order {
  id           Int         @id @default(autoincrement())
  serviceId    Int
  buyerId      Int
  sellerId     Int
  amount       Float
  requirements String?
  status       OrderStatus @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  service      Service     @relation(fields: [serviceId], references: [id])
  buyer        User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller       User        @relation("SellerOrders", fields: [sellerId], references: [id])
  messages     OrderMessage[]
  review       Review?
  dispute      Dispute?
}

model OrderMessage {
  id        Int      @id @default(autoincrement())
  orderId   Int
  senderId  Int
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order        Order                     @relation(fields: [orderId], references: [id])
  sender       User                      @relation(fields: [senderId], references: [id])
  attachments  OrderMessageAttachment[]
}

model OrderMessageAttachment {
  id         Int      @id @default(autoincrement())
  messageId  Int
  fileName   String
  fileUrl    String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  message    OrderMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model Review {
  id          Int      @id @default(autoincrement())
  orderId     Int      @unique
  reviewerId  Int
  revieweeId  Int
  rating      Int
  comment     String?
  sellerReply String?
  sellerReplyAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer    User     @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  reviewee    User     @relation("RevieweeReviews", fields: [revieweeId], references: [id])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

model Dispute {
  id         Int          @id @default(autoincrement())
  orderId    Int          @unique
  buyerId    Int
  sellerId   Int
  raisedById Int
  reason     String
  status     DisputeStatus @default(OPEN)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer      User         @relation("BuyerDisputes", fields: [buyerId], references: [id])
  seller     User         @relation("SellerDisputes", fields: [sellerId], references: [id])
  raisedBy   User         @relation("RaisedDisputes", fields: [raisedById], references: [id])
  messages   DisputeMessage[]
}

model DisputeMessage {
  id          Int      @id @default(autoincrement())
  disputeId   Int
  senderId    Int
  content     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dispute      Dispute                    @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  sender       User                       @relation(fields: [senderId], references: [id])
  attachments  DisputeMessageAttachment[]
}

model DisputeMessageAttachment {
  id         Int      @id @default(autoincrement())
  messageId  Int
  fileName   String
  fileUrl    String
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  message    DisputeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}
